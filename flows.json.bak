    {
        "id": "refresh_hosts_rate_limit",
        "type": "function",
        "z": "d35afda971f87177",
        "name": "queue host refresh",
        "func": "const queue = context.get('queue') || [];\nlet busy = context.get('busy') || false;\n\nfunction next() {\n  if (queue.length === 0) {\n    context.set('busy', false);\n    context.set('queue', queue);\n    return null;\n  }\n\n  const nextMsg = queue.shift();\n  context.set('queue', queue);\n  context.set('busy', true);\n  return nextMsg;\n}\n\nif (msg._waitDone) {\n  if (msg._waitDone === 'timeout') {\n    context.set('queue', []);\n    context.set('busy', false);\n    return null;\n  }\n\n  context.set('busy', false);\n  return next();\n}\n\nqueue.push(msg);\ncontext.set('queue', queue);\n\nif (!busy) {\n  return next();\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1130,
