    {
        "id": "restart_wait_get",
        "type": "http request",
        "z": "47309e7eb1ed7972",
        "name": "",
        "method": "use",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": true,
        "headers": [],
        "x": 2130,
        "y": 430,
        "wires": [
            [
                "restart_wait_check"
            ]
        ]
    },
    {
        "id": "restart_wait_check",
        "type": "function",
        "z": "47309e7eb1ed7972",
        "name": "container ready?",
        "func": "function valueOf(value) {\n  if (value && typeof value === 'object') {\n    return String(value.value || value.label || value.display || value.name || '').toLowerCase();\n  }\n  return String(value || '').toLowerCase();\n}\n\nconst item = msg.payload && Array.isArray(msg.payload.results) ? msg.payload.results[0] : msg.payload;\nconst name = msg.wait_name || (item && (item.display || item.name)) || msg.wait_id;\nconst status = valueOf(item && item.status);\nconst operation = valueOf(item && item.operation);\nconst operationDone = !operation || operation === 'none' || operation === 'null';\nconst ready = status === 'running' && operationDone;\n\nmsg.wait_name = name;\nmsg.wait_status = status || 'unknown';\nmsg.wait_operation = operation || 'none';\n\nif (ready) {\n  return [msg, null, null];\n}\n\nif (Date.now() >= Number(msg.wait_deadline || 0)) {\n  return [null, null, msg];\n}\n\nreturn [null, msg, null];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2340,
        "y": 430,
        "wires": [
            [
                "restart_wait_ready_log"
            ],
            [
                "restart_wait_poll_delay"
            ],
            [
                "restart_wait_timeout_log"
            ]
        ]
    },
    {
        "id": "restart_wait_poll_delay",
        "type": "delay",
        "z": "47309e7eb1ed7972",
        "name": "poll ready",
        "pauseType": "delay",
        "timeout": "2",
        "timeoutUnits": "seconds",
        "rate": "1",
        "nbRateUnits": "1",
        "rateUnits": "second",
        "randomFirst": "1",
        "randomLast": "5",
        "randomUnits": "seconds",
        "drop": false,
        "allowrate": false,
        "outputs": 1,
        "x": 2340,
        "y": 500,
        "wires": [
            [
                "restart_wait_prepare"
            ]
        ]
    },
    {
        "id": "restart_wait_ready_log",
        "type": "function",
        "z": "47309e7eb1ed7972",
        "name": "log ready",
        "func": "const logs = global.get('logs') || '';\nconst line = new Date().toISOString() + ' RESTART : ' + (msg.wait_name || msg.wait_id) + ' ready<br>';\nglobal.set('logs', line + logs);\nmsg._waitDone = 'success';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2550,
        "y": 400,
        "wires": [
            [
                "83ec24b3be755314"
            ]
        ]
    },
    {
        "id": "restart_wait_timeout_log",
        "type": "function",
        "z": "47309e7eb1ed7972",
        "name": "log timeout",
        "func": "const logs = global.get('logs') || '';\nconst timeout = Number(msg.wait_timeout || 30);\nconst detail = msg.wait_status ? (' status=' + msg.wait_status + ' operation=' + msg.wait_operation) : (' operation=' + msg.wait_operation);\nconst line = new Date().toISOString() + ' RESTART : ' + (msg.wait_name || msg.wait_id) + ' timeout after ' + timeout + 's' + detail + ', stopped<br>';\nglobal.set('logs', line + logs);\nmsg._waitDone = 'timeout';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2550,
        "y": 460,
        "wires": [
            [
                "83ec24b3be755314"
            ]
        ]
