    {
        "id": "1d13b67923d9a132",
        "type": "change",
        "z": "d5158039611d4b98",
        "name": "configure container",
        "rules": [
            {
                "t": "set",
                "p": "container",
                "pt": "msg",
                "to": "payload",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "volume",
                "pt": "msg",
                "to": "payload",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "url",
                "pt": "msg",
                "to": "msg.netbox & \"/api/plugins/docker/containers/\"",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "payload",
                "pt": "msg",
                "to": "(\n  $defaultMounts := [\n    {\n      \"source\": \"/app/data\",\n      \"volume\": {\n        \"name\": msg.instanceShort & \"-data\"\n      },\n      \"read_only\": false\n    }\n  ];\n  $formMounts := $type(msg.volume_source) = \"array\" ? $append([], $filter($map(msg.volume_source, function($source, $i) {\n    {\n      \"source\": $source,\n      \"volume\": {\n        \"name\": msg.volume_name[$i]\n      },\n      \"read_only\": false\n    }\n  }), function($mount) { $mount.source and $mount.volume.name })) : (msg.volume_source and msg.volume_name ? [\n    {\n      \"source\": msg.volume_source,\n      \"volume\": {\n        \"name\": msg.volume_name\n      },\n      \"read_only\": false\n    }\n  ] : []);\n  $env := $type(msg.var_env_key) = \"array\" ? $append([], $filter($map(msg.var_env_key, function($key, $i) {\n    {\n      \"var_name\": $key,\n      \"value\": msg.var_env_value[$i]\n    }\n  }), function($item) { $item.var_name })) : (msg.var_env_key ? [\n    {\n      \"var_name\": msg.var_env_key,\n      \"value\": msg.var_env_value\n    }\n  ] : []);\n  $baseLabels := [\n    {\n      \"key\": \"traefik.enable\",\n      \"value\": \"true\"\n    },\n    {\n      \"key\": \"traefik.http.routers.\" & msg.instanceShort & \".rule\",\n      \"value\": \"Host(`\" & msg.instance & \"`)\"\n    },\n    {\n      \"key\": \"traefik.http.routers.\" & msg.instanceShort & \".entrypoints\",\n      \"value\": \"http\"\n    },\n    {\n      \"key\": \"traefik.http.services.\" & msg.instanceShort & \".loadbalancer.server.port\",\n      \"value\": \"3000\"\n    },\n    {\n      \"key\": \"traefik.http.middlewares.force-https-header.headers.customrequestheaders.X-Forwarded-Proto\",\n      \"value\": \"https\"\n    },\n    {\n      \"key\": \"traefik.http.middlewares.\" & msg.instanceShort & \".ipallowlist.sourcerange\",\n      \"value\": \"173.245.48.0/20, 103.21.244.0/22, 103.22.200.0/22, 103.31.4.0/22, 141.101.64.0/18, 108.162.192.0/18, 190.93.240.0/20, 188.114.96.0/20, 197.234.240.0/22, 198.41.128.0/17, 162.158.0.0/15, 104.16.0.0/13, 104.24.0.0/14, 172.64.0.0/13, 131.0.72.0/22, 2400:cb00::/32, 2606:4700::/32, 2803:f800::/32, 2405:b500::/32, 2405:8100::/32, 2a06:98c0::/29, 2c0f:f248::/32\"\n    },\n    {\n      \"key\": \"traefik.http.routers.\" & msg.instanceShort & \".middlewares\",\n      \"value\": \"force-https-header,\" & msg.instanceShort\n    }\n  ];\n  $extraLabels := $type(msg.label_key) = \"array\" ? $append([], $filter($map(msg.label_key, function($key, $i) {\n    {\n      \"key\": $key,\n      \"value\": msg.label_value[$i]\n    }\n  }), function($label) { $label.key })) : (msg.label_key ? [\n    {\n      \"key\": msg.label_key,\n      \"value\": msg.label_value\n    }\n  ] : []);\n  [\n    {\n      \"id\": msg.container.id,\n      \"host\": msg.host_id,\n      \"network_settings\": [\n        {\n          \"network\": {\n            \"host\": msg.host_id,\n            \"name\": msg.network\n          }\n        }\n      ],\n      \"mounts\": $count($formMounts) > 0 ? $formMounts : $defaultMounts,\n      \"env\": $env,\n      \"labels\": $append($baseLabels, $extraLabels)\n    }\n  ]\n)",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "headers",
                "pt": "msg",
                "to": "{\t   \"Authorization\": \"Token \" & msg.token,\t   \"Content-Type\": \"application/json\"\t}\t",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "method",
                "pt": "msg",
                "to": "PATCH",
                "tot": "str"
            }
        ],
