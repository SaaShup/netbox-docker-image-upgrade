                "recreate_wait_check"
            ]
        ]
    },
    {
        "id": "recreate_wait_check",
        "type": "function",
        "z": "a0840e5d7cd65ea0",
        "name": "container ready?",
        "func": "function valueOf(value) {\n  if (value && typeof value === 'object') {\n    return String(value.value || value.label || value.display || value.name || '').toLowerCase();\n  }\n  return String(value || '').toLowerCase();\n}\n\nconst item = msg.payload && Array.isArray(msg.payload.results) ? msg.payload.results[0] : msg.payload;\nconst name = msg.wait_name || (item && (item.display || item.name)) || msg.wait_id;\nconst status = valueOf(item && item.status);\nconst operation = valueOf(item && item.operation);\nconst operationDone = !operation || operation === 'none' || operation === 'null';\nconst ready = status === 'running' && operationDone;\n\nmsg.wait_name = name;\nmsg.wait_status = status || 'unknown';\nmsg.wait_operation = operation || 'none';\n\nif (ready) {\n  return [msg, null, null];\n}\n\nif (Date.now() >= Number(msg.wait_deadline || 0)) {\n  return [null, null, msg];\n}\n\nreturn [null, msg, null];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2750,
        "y": 620,
        "wires": [
            [
                "recreate_wait_ready_log"
            ],
            [
                "recreate_wait_poll_delay"
            ],
            [
                "recreate_wait_timeout_log"
            ]
        ]
    },
    {
        "id": "recreate_wait_poll_delay",
        "type": "delay",
        "z": "a0840e5d7cd65ea0",
        "name": "poll ready",
        "pauseType": "delay",
        "timeout": "2",
        "timeoutUnits": "seconds",
        "rate": "1",
        "nbRateUnits": "1",
        "rateUnits": "second",
        "randomFirst": "1",
        "randomLast": "5",
        "randomUnits": "seconds",
        "drop": false,
        "allowrate": false,
        "outputs": 1,
        "x": 2750,
        "y": 690,
        "wires": [
            [
                "recreate_wait_prepare"
            ]
        ]
    },
    {
        "id": "recreate_wait_ready_log",
        "type": "function",
        "z": "a0840e5d7cd65ea0",
        "name": "log ready",
        "func": "const logs = global.get('logs') || '';\nconst line = new Date().toISOString() + ' RECREATE : ' + (msg.wait_name || msg.wait_id) + ' ready<br>';\nglobal.set('logs', line + logs);\nmsg._waitDone = 'success';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2960,
        "y": 590,
        "wires": [
            [
                "677c1ef45acfb02d"
            ]
        ]
    },
    {
        "id": "recreate_wait_timeout_log",
        "type": "function",
        "z": "a0840e5d7cd65ea0",
        "name": "log timeout",
        "func": "const logs = global.get('logs') || '';\nconst timeout = Number(msg.wait_timeout || 30);\nconst detail = msg.wait_status ? (' status=' + msg.wait_status + ' operation=' + msg.wait_operation) : (' operation=' + msg.wait_operation);\nconst line = new Date().toISOString() + ' RECREATE : ' + (msg.wait_name || msg.wait_id) + ' timeout after ' + timeout + 's' + detail + ', stopped<br>';\nglobal.set('logs', line + logs);\nmsg._waitDone = 'timeout';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2960,
        "y": 650,
        "wires": [
            [
                "677c1ef45acfb02d"
            ]
        ]
    },
