    {
        "id": "3cf9824c67655d6f",
        "type": "change",
        "z": "d5158039611d4b98",
        "name": "create volume",
        "rules": [
            {
                "t": "set",
                "p": "input",
                "pt": "msg",
                "to": "payload",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "url",
                "pt": "msg",
                "to": "msg.netbox & \"/api/plugins/docker/volumes/\"",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "payload",
                "pt": "msg",
                "to": "(\n  $defaultVolumes := [\n    {\n      \"host\": msg.host_id,\n      \"name\": msg.instanceShort & \"-data\"\n    }\n  ];\n  $formVolumes := $type(msg.volume_name) = \"array\" ? $append([], $filter($map(msg.volume_name, function($name) {\n    {\n      \"host\": msg.host_id,\n      \"name\": $name\n    }\n  }), function($volume) { $volume.name })) : (msg.volume_name ? [\n    {\n      \"host\": msg.host_id,\n      \"name\": msg.volume_name\n    }\n  ] : []);\n  $volumes := $count($formVolumes) > 0 ? $formVolumes : $defaultVolumes;\n  $count($volumes) = 1 ? $volumes[0] : $volumes\n)",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "headers",
                "pt": "msg",
                "to": "{\t   \"Authorization\": \"Token \" & msg.token,\t   \"Content-Type\": \"application/json\"\t}\t",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "method",
                "pt": "msg",
                "to": "POST",
                "tot": "str"
            }
        ],
        "action": "",
        "property": "",
        "from": "",
        "to": "",
        "reg": false,
        "x": 890,
        "y": 300,
        "wires": [
            [
                "apply_proxy_1233e36c1ed40b2c"
            ]
        ]
