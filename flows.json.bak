        "id": "refresh_hosts_wait_prepare",
        "type": "function",
        "z": "d35afda971f87177",
        "name": "wait host ready",
        "func": "const timeout = Number(msg.wait_timeout || 30);\nmsg.wait_deadline = msg.wait_deadline || (Date.now() + timeout * 1000);\nmsg.url = msg.netbox + '/api/plugins/docker/hosts/' + msg.wait_id + '/';\nmsg.headers = {\n  Authorization: 'Token ' + msg.token,\n  Accept: 'application/json'\n};\nmsg.method = 'GET';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1370,
        "y": 300,
