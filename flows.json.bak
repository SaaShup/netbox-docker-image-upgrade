    {
        "id": "subflow_apply_proxy",
        "type": "subflow",
        "name": "Apply proxy",
        "info": "Applies the selected profile proxy to Node-RED HTTP requests and disables TLS certificate verification for NetBox calls.",
        "category": "",
        "in": [
            {
                "x": 40,
                "y": 80,
                "wires": [
                    {
                        "id": "subflow_apply_proxy_change"
                    }
                ]
            }
        ],
        "out": [
            {
                "x": 440,
                "y": 80,
                "wires": [
                    {
                        "id": "subflow_apply_proxy_change",
                        "port": 0
                    }
                ]
            }
        ],
        "env": [],
        "meta": {},
        "color": "#DDAA99"
    },
    {
        "id": "subflow_apply_proxy_change",
        "type": "change",
        "z": "subflow_apply_proxy",
        "name": "apply proxy settings",
        "rules": [
            {
                "t": "set",
                "p": "rejectUnauthorized",
                "pt": "msg",
                "to": "false",
                "tot": "bool"
            },
            {
                "t": "set",
                "p": "proxyValue",
                "pt": "msg",
                "to": "msg.proxy ? msg.proxy : (msg.payload.proxy ? msg.payload.proxy : \"\")",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "proxyEnv.http_proxy",
                "pt": "global",
                "to": "proxyValue",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "proxyEnv.https_proxy",
                "pt": "global",
                "to": "proxyValue",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "proxyEnv.HTTP_PROXY",
                "pt": "global",
                "to": "proxyValue",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "proxyEnv.HTTPS_PROXY",
                "pt": "global",
                "to": "proxyValue",
                "tot": "msg"
            },
            {
                "t": "delete",
                "p": "proxyValue",
                "pt": "msg"
            }
        ],
        "action": "",
        "property": "",
        "from": "",
        "to": "",
        "reg": false,
        "x": 160,
        "y": 80,
        "wires": [
            []
        ]
    },
