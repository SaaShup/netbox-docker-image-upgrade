    {
        "id": "restart_wait_prepare",
        "type": "function",
        "z": "47309e7eb1ed7972",
        "name": "wait container ready",
        "func": "const timeout = Number(msg.wait_timeout || 30);\nmsg.wait_deadline = msg.wait_deadline || (Date.now() + timeout * 1000);\nmsg.url = msg.netbox + '/api/plugins/docker/containers/' + msg.wait_id + '/';\nmsg.headers = {\n  Authorization: 'Token ' + msg.token,\n  Accept: 'application/json'\n};\nmsg.method = 'GET';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1680,
        "y": 430,
        "wires": [
