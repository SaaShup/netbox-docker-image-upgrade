    {
        "id": "2dcca2a38409fe43",
        "type": "change",
        "z": "d5158039611d4b98",
        "name": "",
        "rules": [
            {
                "t": "set",
                "p": "config",
                "pt": "msg",
                "to": "payload",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "netbox",
                "pt": "msg",
                "to": "config.netbox ? config.netbox : (req.query.netbox ? req.query.netbox : $globalContext(\"config\").netbox)",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "token",
                "pt": "msg",
                "to": "config.token ? config.token : (req.query.token ? req.query.token : $globalContext(\"config\").token)",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "proxy",
                "pt": "msg",
                "to": "config.proxy ? config.proxy : (req.query.proxy ? req.query.proxy : $globalContext(\"config\").proxy)",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "hostname",
                "pt": "msg",
                "to": "config.hostname",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "version",
                "pt": "msg",
                "to": "config.version",
                "tot": "global"
            },
            {
                "t": "set",
                "p": "network",
                "pt": "msg",
                "to": "config.network",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "var_env_key",
                "pt": "msg",
                "to": "config.var_env_key",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "var_env_value",
                "pt": "msg",
                "to": "config.var_env_value",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "label_key",
                "pt": "msg",
                "to": "config.label_key",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "label_value",
                "pt": "msg",
                "to": "config.label_value",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "volume_source",
                "pt": "msg",
                "to": "config.volume_source",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "volume_name",
                "pt": "msg",
                "to": "config.volume_name",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "instance",
                "pt": "msg",
                "to": "config.instance",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "instanceShort",
                "pt": "msg",
                "to": "($contains(msg.instance, \".\") ? $substringBefore(msg.instance, \".\") : msg.instance)",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "instanceZone",
                "pt": "msg",
                "to": "$substringAfter(msg.instance, \".\")",
                "tot": "jsonata"
            },
            {
                "t": "set",
                "p": "image",
                "pt": "msg",
                "to": "config.image",
                "tot": "msg"
            },
            {
                "t": "set",
                "p": "http",
                "pt": "msg",
                "to": "true",
                "tot": "bool"
            }
        ],
        "action": "",
        "property": "",
        "from": "",
        "to": "",
        "reg": false,
        "x": 260,
        "y": 220,
        "wires": [
            [
                "458387080417f52a",
                "c9baa00a19d15c11"
            ]
        ]
