    {
        "id": "refresh_hosts_wait_check",
        "type": "function",
        "z": "d35afda971f87177",
        "name": "host ready?",
        "func": "function valueOf(value) {\n  if (value && typeof value === 'object') {\n    return String(value.value || value.label || value.display || value.name || '').toLowerCase();\n  }\n  return String(value || '').toLowerCase();\n}\n\nconst item = msg.payload && Array.isArray(msg.payload.results) ? msg.payload.results[0] : msg.payload;\nconst name = msg.wait_name || (item && (item.display || item.name)) || msg.wait_id;\nconst operation = valueOf(item && item.operation);\nconst operationDone = !operation || operation === 'none' || operation === 'null';\n\nmsg.wait_name = name;\nmsg.wait_operation = operation || 'none';\n\nif (operationDone) {\n  return [msg, null, null];\n}\n\nif (Date.now() >= Number(msg.wait_deadline || 0)) {\n  return [null, null, msg];\n}\n\nreturn [null, msg, null];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2030,
        "y": 300,
        "wires": [
            [
                "refresh_hosts_wait_ready_log"
            ],
            [
                "refresh_hosts_wait_poll_delay"
            ],
            [
                "refresh_hosts_wait_timeout_log"
            ]
        ]
    },
    {
        "id": "refresh_hosts_wait_poll_delay",
        "type": "delay",
        "z": "d35afda971f87177",
        "name": "poll ready",
        "pauseType": "delay",
        "timeout": "2",
        "timeoutUnits": "seconds",
        "rate": "1",
        "nbRateUnits": "1",
        "rateUnits": "second",
        "randomFirst": "1",
        "randomLast": "5",
        "randomUnits": "seconds",
        "drop": false,
        "allowrate": false,
        "outputs": 1,
        "x": 2030,
        "y": 370,
        "wires": [
            [
                "refresh_hosts_wait_prepare"
            ]
        ]
    },
    {
        "id": "refresh_hosts_wait_ready_log",
        "type": "function",
        "z": "d35afda971f87177",
        "name": "log ready",
        "func": "const logs = global.get('logs') || '';\nconst line = new Date().toISOString() + ' REFRESH_HOST : ' + (msg.wait_name || msg.wait_id) + ' ready<br>';\nglobal.set('logs', line + logs);\nmsg._waitDone = 'success';\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2240,
        "y": 270,
        "wires": [
