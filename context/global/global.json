{
    "proxyEnv": {
        "http_proxy": "",
        "https_proxy": "",
        "HTTP_PROXY": "",
        "HTTPS_PROXY": ""
    },
    "logs": "",
    "templates": {
        "saashup/curioo-tiles": {
            "network": "traefik_network",
            "instance": "curioo-tiles",
            "image": "saashup/curioo-tiles",
            "version": "latest",
            "env": [
                {
                    "key": "OVERPASS_URL",
                    "value": "https://overpass1.curioo.city/api/interpreter"
                }
            ],
            "labels": [],
            "volumes": [
                {
                    "key": "/app/cache",
                    "value": "curioo-tiles-cache"
                }
            ]
        }
    }
}